# Supabase — budget.abdielvega.com
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<publishable key, starts with sb_publishable_ or eyJ>

# GitHub API — used by /projects page to list repos
GITHUB_TOKEN=<github-personal-access-token>

# ── SMTP (contact form) ──────────────────────────────────────────
# Defaults are iCloud. Override SMTP_HOST / SMTP_PORT for another provider.
# iCloud: smtp.mail.me.com on port 587 (STARTTLS). Requires an app-specific
# password generated at https://appleid.apple.com → Sign-In & Security.
SMTP_HOST=smtp.mail.me.com
SMTP_PORT=587
SMTP_USER=<your-apple-id@icloud.com>
EMAIL_PASSWORD=<app-specific-password-from-appleid.apple.com>

# The "From" address recipients will see. Usually me@abdielvega.com.
# If sending from a custom domain, it must be verified in iCloud Mail
# (iCloud+ Custom Email Domain) and listed as an allowed sender.
EMAIL=me@abdielvega.com

# Where contact-form submissions land (defaults to EMAIL if unset)
CONTACT_INBOX=me@abdielvega.com
