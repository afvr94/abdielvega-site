# Supabase — budget.abdielvega.com
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# GitHub API — used by /projects page to list repos
GITHUB_TOKEN=<github-personal-access-token>

# Contact form (Namecheap Private Email via SMTP)
EMAIL=me@abdielvega.com
EMAIL_PASSWORD=<smtp-password>

# Email that receives contact-form submissions (defaults to EMAIL if unset)
CONTACT_INBOX=me@abdielvega.com
